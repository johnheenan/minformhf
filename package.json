{
  "name": "Minformhf",
  "version": "0.2.5",
  "description": "Website template starter with markdown and minimalist forms for Hostfurl",
  "private": true,
  "type": "module",
  "workspaces": [
    "do"
  ],
  "scripts": {
    "start": "ELTY_OPTIONS='--input=./site-1' npm -w do run start",
    "stage": "ELTY_OPTIONS='--input=./site-1' npm -w do run stage",
    "build": "ELTY_OPTIONS='--input=./site-1' npm -w do run build",
    "prestage": "curl https://raw.githubusercontent.com/anyblades/bladeswitch/refs/heads/main/admin/index.html -o ./_public/admin/index.html",
    "syncblades": "./minform/syncblades.js",
    "postinstall": "npm run syncblades"
  },
  "author": "John Heenan and others",
  "license": "MIT",
  "devDependencies": {
    "eleventy-auto-cache-buster": "^0.9.2",
    "prettier-plugin-jinja-template": "^2.1.0",
    "serve": "^14.2.5"
  },
  "dependencies": {
    "@11ty/eleventy": "^4.0.0-alpha.6",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@anyblades/blades": "^0.28.0-alpha.2",
    "@anyblades/eleventy-blades": "^0.28.0-beta.3",
    "@anyblades/pico": "^2.2.0-alpha.5",
    "@tailwindcss/cli": "^4.2.1",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1"
  }
}
